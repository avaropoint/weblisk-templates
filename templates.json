{
  "version": "1.0.0",
  "description": "Official Weblisk project templates",

  "categories": {
    "scaffold": {
      "description": "Full-page templates used during project scaffolding",
      "path": "scaffold/"
    },
    "page": {
      "description": "Standalone page templates for `weblisk add page`",
      "path": "page/"
    },
    "island": {
      "description": "Island component templates for `weblisk add island`",
      "path": "island/"
    },
    "core": {
      "description": "Core project files included in every scaffold",
      "path": "core/"
    }
  },

  "sets": {
    "default": {
      "description": "Minimal starter — home page and 404",
      "scaffold": ["home.html.tpl", "404.html.tpl"]
    },
    "blog": {
      "description": "Blog starter with posts and about page",
      "scaffold": ["home.html.tpl", "404.html.tpl", "blog.html.tpl", "about.html.tpl"]
    },
    "dashboard": {
      "description": "Dashboard app with settings panel",
      "scaffold": ["home.html.tpl", "404.html.tpl", "dashboard.html.tpl", "settings.html.tpl"]
    },
    "docs": {
      "description": "Documentation site with sidebar navigation",
      "scaffold": ["home.html.tpl", "404.html.tpl", "docs.html.tpl"]
    }
  },

  "core": [
    "styles.css.tpl",
    "sw.js.tpl",
    "shell.js.tpl",
    "env.tpl",
    "gitignore.tpl"
  ]
}
